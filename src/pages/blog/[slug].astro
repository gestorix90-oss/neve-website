---
import SiteLayout from '../../layouts/SiteLayout.astro';
import NewsletterCTA from '../../components/NewsletterCTA.astro';
import { getCollection } from 'astro:content';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<SiteLayout 
  title={post.data.title} 
  description={post.data.description}
  image={post.data.image}
>
  <article class="blog-post">
    <div class="container">
      <header class="post-header">
        <a href="/blog" class="back-link">← Torna al Blog</a>
        <div class="post-meta">
          <span class="post-date">{post.data.date.toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
          {post.data.category && <span class="post-category">{post.data.category}</span>}
          {post.data.readingTime && <span class="reading-time">{post.data.readingTime} min di lettura</span>}
        </div>
        <h1>{post.data.title}</h1>
        <p class="post-subtitle">{post.data.description}</p>
      </header>
      
      <div class="post-content">
        <Content />
      </div>
      
      <footer class="post-footer">
        <div class="share-links">
          <span>Condividi:</span>
          <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${Astro.url}`} target="_blank" rel="noopener">X/Twitter</a>
          <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${Astro.url}`} target="_blank" rel="noopener">LinkedIn</a>
        </div>
      </footer>
    </div>
  </article>
  
  <NewsletterCTA />
</SiteLayout>

<style>
  .blog-post {
    padding: 4rem 2rem;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .post-header {
    margin-bottom: 3rem;
  }

  .post-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .post-date {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .post-category {
    background: rgba(201, 168, 76, 0.1);
    color: var(--accent);
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .reading-time {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .post-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    line-height: 1.2;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .post-subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .post-content {
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .post-content h2 {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 3rem 0 1.5rem;
    color: var(--text);
  }

  .post-content h3 {
    font-size: 1.4rem;
    font-weight: 600;
    margin: 2rem 0 1rem;
    color: var(--text);
  }

  .post-content p {
    margin-bottom: 1.5rem;
    color: var(--text);
  }

  .post-content ul,
  .post-content ol {
    margin-bottom: 1.5rem;
    padding-left: 2rem;
  }

  .post-content li {
    margin-bottom: 0.5rem;
  }

  .post-content blockquote {
    border-left: 4px solid var(--accent);
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    background: var(--card-bg);
    border-radius: 0 8px 8px 0;
    font-style: italic;
    color: var(--text-muted);
  }

  .post-content code {
    background: var(--card-bg);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .post-content pre {
    background: var(--card-bg);
    padding: 1.5rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 2rem 0;
  }

  .post-content pre code {
    background: none;
    padding: 0;
  }

  .post-content a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-content img {
    border-radius: 12px;
    margin: 2rem 0;
  }

  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .share-links {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--text-muted);
  }

  .share-links a {
    color: var(--accent);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .blog-post {
      padding: 2rem 1.5rem;
    }

    .post-content {
      font-size: 1rem;
    }
  }
</style>

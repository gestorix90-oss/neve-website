---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categories = [...new Set(posts.map(p => p.data.category).filter(Boolean))];
const currentCategory = Astro.url.searchParams.get('category');
const filteredPosts = currentCategory 
  ? posts.filter(p => p.data.category === currentCategory)
  : posts;
---

<SiteLayout title="Blog" description="Articoli su psicologia del denaro, bias cognitivi e finanza comportamentale.">
  <section class="blog-page">
    <div class="container">
      <div class="blog-header">
        <h1>Blog</h1>
        <p>Psicologia del denaro spiegata con metafore dall'officina.</p>
      </div>
      
      <div class="blog-layout">
        <aside class="sidebar">
          <h3>Categorie</h3>
          <ul class="category-list">
            <li>
              <a href="/blog" class:list={[!currentCategory && 'active']}>Tutti</a>
            </li>
            {categories.map(cat => (
              <li>
                <a href={`/blog?category=${cat}`} class:list={[currentCategory === cat && 'active']}>{cat}</a>
              </li>
            ))}
          </ul>
        </aside>
        
        <div class="posts-list">
          {filteredPosts.map(post => (
            <article class="post-item">
              <div class="post-meta">
                <span class="post-date">{post.data.date.toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
                {post.data.category && <span class="post-category">{post.data.category}</span>}
                {post.data.readingTime && <span class="reading-time">{post.data.readingTime} min</span>}
              </div>
              <h2>
                <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
              </h2>
              <p>{post.data.description}</p>
              <a href={`/blog/${post.slug}/`} class="read-more">Leggi tutto →</a>
            </article>
          ))}
          
          {filteredPosts.length === 0 && (
            <div class="empty-state">
              <p>Nessun articolo in questa categoria.</p>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
</SiteLayout>

<style>
  .blog-page {
    padding: 4rem 2rem;
    min-height: calc(100vh - 80px);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .blog-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .blog-header h1 {
    font-size: 3rem;
    font-weight: 900;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .blog-header p {
    font-size: 1.1rem;
    color: var(--text-muted);
  }

  .blog-layout {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 3rem;
  }

  .sidebar {
    position: sticky;
    top: 100px;
    height: fit-content;
  }

  .sidebar h3 {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
    color: var(--accent);
  }

  .category-list {
    list-style: none;
  }

  .category-list li {
    margin-bottom: 0.5rem;
  }

  .category-list a {
    display: block;
    padding: 0.5rem 1rem;
    color: var(--text-muted);
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .category-list a:hover,
  .category-list a.active {
    background: rgba(201, 168, 76, 0.1);
    color: var(--accent);
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .post-item {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    transition: all 0.3s ease;
  }

  .post-item:hover {
    border-color: var(--accent);
    transform: translateY(-3px);
  }

  .post-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .post-date {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .post-category {
    background: rgba(201, 168, 76, 0.1);
    color: var(--accent);
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .reading-time {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .post-item h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .post-item h2 a {
    color: var(--text);
  }

  .post-item h2 a:hover {
    color: var(--accent);
  }

  .post-item p {
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .read-more {
    color: var(--accent);
    font-weight: 600;
  }

  .empty-state {
    text-align: center;
    padding: 4rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .blog-page {
      padding: 3rem 1.5rem;
    }

    .blog-layout {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: static;
    }

    .category-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .blog-header h1 {
      font-size: 2.5rem;
    }
  }
</style>

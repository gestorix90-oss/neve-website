---
---

<section class="hero">
  <div class="hero-content">
    <div class="hero-badge">🔧 Finanza Comportamentale</div>
    <h1>Ti apro il cofano <br/>dei tuoi <span class="highlight">soldi</span></h1>
    <p class="hero-subtitle">
      Bias cognitivi, errori finanziari e psicologia del denaro spiegati 
      con metafore dall'officina. Perché i tuoi soldi hanno bisogno di un meccanico.
    </p>
    <div class="hero-actions">
      <a href="/blog" class="btn btn-primary">Leggi il Blog</a>
      <a href="/newsletter" class="btn btn-secondary">Iscriviti alla Newsletter</a>
    </div>
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-number">50+</span>
        <span class="stat-label">Articoli</span>
      </div>
      <div class="stat">
        <span class="stat-number">10K+</span>
        <span class="stat-label">Lettori</span>
      </div>
      <div class="stat">
        <span class="stat-number">100%</span>
        <span class="stat-label">Gratis</span>
      </div>
    </div>
  </div>
  <div class="hero-visual">
    <div class="gear-container">
      <svg viewBox="0 0 200 200" class="gear gear-large">
        <path d="M100 20 L110 40 L130 30 L125 55 L150 55 L135 75 L155 90 L130 95 L140 120 L115 110 L105 135 L95 115 L70 125 L80 100 L55 95 L75 80 L60 60 L85 60 L80 35 L100 45 Z" fill="none" stroke="#c9a84c" stroke-width="2"/>
        <circle cx="100" cy="80" r="20" fill="none" stroke="#c9a84c" stroke-width="2"/>
      </svg>
      <svg viewBox="0 0 150 150" class="gear gear-small">
        <path d="M75 15 L82 30 L97 22 L94 42 L115 42 L104 58 L118 70 L98 74 L106 92 L88 84 L82 102 L76 86 L60 94 L68 78 L48 74 L62 62 L48 50 L68 46 L60 28 L78 36 Z" fill="none" stroke="#c9a84c" stroke-width="1.5" opacity="0.6"/>
        <circle cx="75" cy="60" r="15" fill="none" stroke="#c9a84c" stroke-width="1.5" opacity="0.6"/>
      </svg>
    </div>
  </div>
</section>

<style>
  .hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 6rem 2rem 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    min-height: calc(100vh - 80px);
  }

  .hero-badge {
    display: inline-block;
    background: rgba(201, 168, 76, 0.1);
    border: 1px solid rgba(201, 168, 76, 0.3);
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.85rem;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: var(--text);
  }

  .highlight {
    color: var(--accent);
    position: relative;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 500px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 2rem;
    border-radius: 10px;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--bg);
  }

  .btn-primary:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(201, 168, 76, 0.3);
  }

  .btn-secondary {
    background: transparent;
    border: 2px solid var(--border);
    color: var(--text);
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .hero-stats {
    display: flex;
    gap: 3rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
  }

  .stat-number {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--accent);
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .gear-container {
    position: relative;
    width: 300px;
    height: 300px;
  }

  .gear-large {
    position: absolute;
    top: 0;
    left: 0;
    width: 200px;
    animation: rotate 20s linear infinite;
  }

  .gear-small {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 150px;
    animation: rotate-reverse 15s linear infinite;
  }

  @keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes rotate-reverse {
    from { transform: rotate(360deg); }
    to { transform: rotate(0deg); }
  }

  @media (max-width: 968px) {
    .hero {
      grid-template-columns: 1fr;
      text-align: center;
      padding: 4rem 1.5rem 3rem;
      min-height: auto;
    }

    .hero-subtitle {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-stats {
      justify-content: center;
    }

    .hero-visual {
      order: -1;
    }

    .gear-container {
      width: 200px;
      height: 200px;
    }

    .gear-large {
      width: 140px;
    }

    .gear-small {
      width: 100px;
    }
  }
</style>

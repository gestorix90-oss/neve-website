---
const { posts } = Astro.props;
---

<section class="latest-posts">
  <div class="container">
    <div class="section-header">
      <h2>Ultimi Articoli</h2>
      <p>Le ultime dal blog. Psicologia del denaro spiegata semplice.</p>
      <a href="/blog" class="view-all">Vedi tutti gli articoli →</a>
    </div>
    
    <div class="posts-grid">
      {posts.map(post => (
        <article class="post-card">
          <div class="post-meta">
            <span class="post-date">{post.data.date.toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
            {post.data.category && <span class="post-category">{post.data.category}</span>}
          </div>
          <h3>
            <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
          </h3>
          <p>{post.data.description}</p>
          <a href={`/blog/${post.slug}/`} class="read-more">Leggi tutto →</a>
        </article>
      ))}
    </div>
    
    {posts.length === 0 && (
      <div class="empty-state">
        <p>Nessun articolo pubblicato ancora. Torna presto!</p>
      </div>
    )}
  </div>
</section>

<style>
  .latest-posts {
    padding: 6rem 2rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
    position: relative;
  }

  .section-header h2 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .section-header p {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  .view-all {
    display: inline-block;
    margin-top: 1rem;
    color: var(--accent);
    font-weight: 600;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .post-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .post-card:hover {
    transform: translateY(-5px);
    border-color: var(--accent);
  }

  .post-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .post-date {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .post-category {
    background: rgba(201, 168, 76, 0.1);
    color: var(--accent);
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .post-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .post-card h3 a {
    color: var(--text);
  }

  .post-card h3 a:hover {
    color: var(--accent);
  }

  .post-card p {
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .read-more {
    color: var(--accent);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .empty-state {
    text-align: center;
    padding: 4rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .latest-posts {
      padding: 4rem 1.5rem;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }

    .section-header h2 {
      font-size: 2rem;
    }
  }
</style>
